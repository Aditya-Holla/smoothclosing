# Copy to .env and fill in your keys

# RentCast AVM
RENTCAST_API_KEY=your_rentcast_api_key_here

# Skip Genie
SKIPGENIE_EMAIL=your@email.com
SKIPGENIE_PASSWORD=your_password_here

# RingCentral SMS
RC_CLIENT_ID=your_rc_client_id
RC_CLIENT_SECRET=your_rc_client_secret
RC_JWT_TOKEN=your_rc_jwt_token
RC_FROM_NUMBER=+15551234567

# Your name for SMS messages
SENDER_NAME=John Smith
