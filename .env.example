# Copy to .env and fill in your keys.
# For Render hosted deploy, paste each KEY + value into the
# Environment tab (render.yaml already declares the keys).

# Anthropic (chat tab + agent orchestrator)
ANTHROPIC_API_KEY=sk-ant-...

# RentCast AVM
RENTCAST_API_KEY=your_rentcast_api_key_here

# Skip Genie
SKIPGENIE_EMAIL=your@email.com
SKIPGENIE_PASSWORD=your_password_here

# RingCentral SMS
RC_CLIENT_ID=your_rc_client_id
RC_CLIENT_SECRET=your_rc_client_secret
RC_JWT_TOKEN=your_rc_jwt_token
RC_FROM_NUMBER=+15551234567

# Your name for SMS messages
SENDER_NAME=John Smith

# Google Sheets export (the long ID from the sheet URL after /d/)
GOOGLE_SHEET_ID=your_sheet_id
DISPOSITIONS_SHEET_ID=your_dispositions_sheet_id

# Google Business Profile (optional — auto-resolved if omitted).
# Pin to skip the two resolve calls each run. From `--account-info`.
GBP_ACCOUNT_ID=accounts/000000000000000000000
GBP_LOCATION_ID=locations/0000000000000000000

# Hosted-only — set on Render to /data, leave unset locally.
# DATA_DIR=/data
